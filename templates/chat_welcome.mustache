<div style="display:flex;gap:.5rem;align-items:flex-start;">
  <div style="width:26px;height:26px;border-radius:50%;background:var(--blue-dim);display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;color:var(--blue);flex-shrink:0;">✦</div>
  <div style="background:var(--panel2);border:1px solid var(--line);border-radius:2px 12px 12px 12px;padding:.6rem .85rem;font-size:.82rem;line-height:1.65;max-width:88%;">
    {{message}}
  </div>
</div>
