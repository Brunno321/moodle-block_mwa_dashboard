{{#messages}}
  <div style="display:flex;gap:.5rem;align-items:flex-start;align-self:{{align}};max-width:88%;{{direction}}">
    <div style="width:26px;height:26px;border-radius:50%;background:{{avatarbg}};display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:700;color:var(--blue);flex-shrink:0;">{{avatarlabel}}</div>
    <div style="{{bubblestyle}}padding:.6rem .85rem;font-size:.8rem;line-height:1.65;">
      {{{contenthtml}}}
    </div>
  </div>
{{/messages}}
